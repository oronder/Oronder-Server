# Copy this file to .env on your server (same directory as docker-compose.yml)

# --------------------
# Required
# --------------------
DISCORD_TOKEN=
DISCORD_CLIENT_SECRET=
API_URL=https://api.example.com

# --------------------
# Configurable
# --------------------
UVICORN_PORT=39054
LOG_LEVEL=INFO

# --------------------
# Database
# --------------------
POSTGRES_DB=oronder
POSTGRES_USER=oronder
POSTGRES_PASSWORD=change_me_or_not_idk
# Don't modify directly!
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@oronder-db:5432/${POSTGRES_DB}

# --------------------
# Backblaze B2 - DB Backups (optional)
# --------------------
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_NOTIFICATION_WEBHOOK=

# --------------------
# Uptime - GitHub API (optional)
# --------------------
GITHUB_UPTIME_PAT=
GITHUB_UPTIME_URL=

# --------------------
# Wiki.js - (optional)
# --------------------
WIKIJS_TOKEN=
WIKIJS_URL=https://wiki.example.com/graphql
